# Database
DATABASE_URL="postgresql://user:password@localhost:5432/lumina_db?schema=public"

# Authentication
NEXTAUTH_SECRET="change-this-to-a-random-string-min-32-chars"
NEXTAUTH_URL="http://localhost:1234"
JWT_SECRET="your-jwt-secret-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# OpenAI (Multi-Agent System)
OPENAI_API_KEY="sk-your-openai-api-key"
OPENAI_ORG_ID=""

# Agent Configuration
AGENT_CONCURRENT_LIMIT="5"
AGENT_TIMEOUT_MS="300000"
AGENT_RETRY_ATTEMPTS="3"

# WebSocket (Real-time Updates)
WS_PORT="3001"
WS_PATH="/ws"

# App Configuration
NODE_ENV="development"
NEXT_PUBLIC_APP_NAME="Lumina AI Learning"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Rate Limiting
RATE_LIMIT_MAX="100"
RATE_LIMIT_WINDOW_MS="900000"

# Logging
LOG_LEVEL="info"
LOG_FILE_PATH="./logs/app.log"

# Vercel Specific (For Production)
# POSTGRES_URL="postgresql://..."
# POSTGRES_PRISMA_URL="postgresql://..."
# POSTGRES_URL_NON_POOLING="postgresql://..."
