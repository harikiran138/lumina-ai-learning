<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %> - Lumina
    </title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/glassmorphism.css">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        .animate-fade-in-up {
            animation: fadeInUp 0.5s ease-out forwards;
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
    <script>
        if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
    </script>
</head>

<body class="bg-gray-50 dark:bg-black text-gray-900 dark:text-white transition-colors duration-300">
    <div class="relative h-screen overflow-hidden lg:flex">

        <!-- Sidebar -->
        <%- include('../partials/sidebar') %>

            <!-- Main Content -->
            <div class="flex-1 flex flex-col w-full lg:w-auto transition-transform duration-300 ease-in-out">

                <!-- Header -->
                <%- include('../partials/header') %>

                    <!-- Community Content -->
                    <main
                        class="flex-1 overflow-x-hidden overflow-y-auto bg-gray-50 dark:bg-black p-6 animate-fade-in-up">

                        <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">

                            <!-- Left Sidebar (Channels) -->
                            <div class="lg:col-span-1 space-y-6">
                                <div
                                    class="bg-white dark:bg-[#1C1C1C] rounded-2xl border border-gray-200 dark:border-gray-800 p-4">
                                    <button
                                        class="w-full py-2 mb-4 bg-[#FF6B35] hover:bg-[#E85A26] text-white rounded-lg font-medium shadow-lg shadow-orange-500/20 transition-colors">
                                        + New Post
                                    </button>

                                    <div class="space-y-1">
                                        <h3
                                            class="px-3 text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">
                                            Channels</h3>
                                        <a href="#"
                                            class="flex items-center px-3 py-2 rounded-lg bg-orange-50 dark:bg-orange-900/20 text-[#FF6B35] font-medium">
                                            <span class="mr-2">#</span> General
                                        </a>
                                        <a href="#"
                                            class="flex items-center px-3 py-2 rounded-lg text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
                                            <span class="mr-2">#</span> Homework Help
                                        </a>
                                        <a href="#"
                                            class="flex items-center px-3 py-2 rounded-lg text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
                                            <span class="mr-2">#</span> Study Groups
                                        </a>
                                        <a href="#"
                                            class="flex items-center px-3 py-2 rounded-lg text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
                                            <span class="mr-2">#</span> Project Ideas
                                        </a>
                                        <a href="#"
                                            class="flex items-center px-3 py-2 rounded-lg text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
                                            <span class="mr-2">#</span> Off-Topic
                                        </a>
                                    </div>
                                </div>

                                <!-- Active Users -->
                                <div
                                    class="bg-white dark:bg-[#1C1C1C] rounded-2xl border border-gray-200 dark:border-gray-800 p-4">
                                    <h3 class="px-3 text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">
                                        Online Now</h3>
                                    <div class="flex -space-x-2 overflow-hidden px-3 mb-3">
                                        <img class="inline-block h-8 w-8 rounded-full ring-2 ring-white dark:ring-[#1C1C1C]"
                                            src="https://i.pravatar.cc/150?u=1" alt="" />
                                        <img class="inline-block h-8 w-8 rounded-full ring-2 ring-white dark:ring-[#1C1C1C]"
                                            src="https://i.pravatar.cc/150?u=2" alt="" />
                                        <img class="inline-block h-8 w-8 rounded-full ring-2 ring-white dark:ring-[#1C1C1C]"
                                            src="https://i.pravatar.cc/150?u=3" alt="" />
                                        <img class="inline-block h-8 w-8 rounded-full ring-2 ring-white dark:ring-[#1C1C1C]"
                                            src="https://i.pravatar.cc/150?u=4" alt="" />
                                        <div
                                            class="h-8 w-8 rounded-full ring-2 ring-white dark:ring-[#1C1C1C] bg-gray-100 dark:bg-gray-800 flex items-center justify-center text-xs font-medium text-gray-500">
                                            +12</div>
                                    </div>
                                </div>
                            </div>

                            <!-- Feed -->
                            <div class="lg:col-span-3 space-y-6">

                                <!-- Post 1 -->
                                <div
                                    class="bg-white dark:bg-[#1C1C1C] rounded-2xl border border-gray-200 dark:border-gray-800 p-6">
                                    <div class="flex items-start justify-between mb-4">
                                        <div class="flex items-center">
                                            <img src="https://i.pravatar.cc/150?u=5" alt="User"
                                                class="w-10 h-10 rounded-full mr-3">
                                            <div>
                                                <h4 class="font-bold text-gray-900 dark:text-white">David Kim</h4>
                                                <span class="text-xs text-gray-500">2 hours ago in <span
                                                        class="text-[#FF6B35]">#Homework Help</span></span>
                                            </div>
                                        </div>
                                        <button
                                            class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300">•••</button>
                                    </div>
                                    <h3 class="text-lg font-bold mb-2 text-gray-900 dark:text-white">Help with Calculus
                                        Integration?</h3>
                                    <p class="text-gray-600 dark:text-gray-300 mb-4">I'm stuck on this integration by
                                        parts problem. Can anyone explain how to choose u and dv? Here's what I've tried
                                        so far...</p>
                                    <div
                                        class="bg-gray-50 dark:bg-gray-900/50 p-3 rounded-lg border border-gray-100 dark:border-gray-800 mb-4 font-mono text-sm text-gray-700 dark:text-gray-300">
                                        ∫ x * e^x dx
                                    </div>
                                    <div class="flex items-center gap-4 text-sm text-gray-500">
                                        <button class="flex items-center gap-1 hover:text-[#FF6B35] transition-colors">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                    d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z">
                                                </path>
                                            </svg>
                                            12 Likes
                                        </button>
                                        <button class="flex items-center gap-1 hover:text-[#FF6B35] transition-colors">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                    d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z">
                                                </path>
                                            </svg>
                                            5 Comments
                                        </button>
                                        <button class="flex items-center gap-1 hover:text-[#FF6B35] transition-colors">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                    d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z">
                                                </path>
                                            </svg>
                                            Share
                                        </button>
                                    </div>
                                </div>

                                <!-- Post 2 -->
                                <div
                                    class="bg-white dark:bg-[#1C1C1C] rounded-2xl border border-gray-200 dark:border-gray-800 p-6">
                                    <div class="flex items-start justify-between mb-4">
                                        <div class="flex items-center">
                                            <img src="https://i.pravatar.cc/150?u=6" alt="User"
                                                class="w-10 h-10 rounded-full mr-3">
                                            <div>
                                                <h4 class="font-bold text-gray-900 dark:text-white">Lisa Wang</h4>
                                                <span class="text-xs text-gray-500">5 hours ago in <span
                                                        class="text-[#FF6B35]">#Project Ideas</span></span>
                                            </div>
                                        </div>
                                        <button
                                            class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300">•••</button>
                                    </div>
                                    <h3 class="text-lg font-bold mb-2 text-gray-900 dark:text-white">Looking for
                                        teammates: AI Weather App 🌦️</h3>
                                    <p class="text-gray-600 dark:text-gray-300 mb-4">I'm starting a project to build a
                                        weather prediction app using historical data. I need someone who knows Python
                                        and Data Visualization. Anyone interested?</p>
                                    <div class="flex items-center gap-4 text-sm text-gray-500">
                                        <button class="flex items-center gap-1 hover:text-[#FF6B35] transition-colors">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                    d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z">
                                                </path>
                                            </svg>
                                            24 Likes
                                        </button>
                                        <button class="flex items-center gap-1 hover:text-[#FF6B35] transition-colors">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                    d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z">
                                                </path>
                                            </svg>
                                            8 Comments
                                        </button>
                                    </div>
                                </div>

                            </div>
                        </div>

                    </main>
            </div>
    </div>

    <!-- Mobile Sidebar Overlay -->
    <div id="sidebar-overlay" class="fixed inset-0 bg-black bg-opacity-50 z-20 hidden" onclick="toggleSidebar()"></div>

    <script src="/js/theme-manager.js"></script>
    <script>
        // Sidebar Toggle
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('sidebar-overlay');
            if (sidebar.classList.contains('-translate-x-full')) {
                sidebar.classList.remove('-translate-x-full');
                overlay.classList.remove('hidden');
            } else {
                sidebar.classList.add('-translate-x-full');
                overlay.classList.add('hidden');
            }
        }

        // Theme Toggle
        const themeToggle = document.getElementById('theme-toggle');
        themeToggle.addEventListener('click', () => {
            if (document.documentElement.classList.contains('dark')) {
                document.documentElement.classList.remove('dark');
                localStorage.setItem('theme', 'light');
            } else {
                document.documentElement.classList.add('dark');
                localStorage.setItem('theme', 'dark');
            }
        });
    </script>
</body>

</html>