<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %> - Lumina
    </title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/glassmorphism.css">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        .animate-fade-in-up {
            animation: fadeInUp 0.5s ease-out forwards;
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
    <script>
        if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
    </script>
</head>

<body class="bg-gray-50 dark:bg-black text-gray-900 dark:text-white transition-colors duration-300">
    <div class="relative h-screen overflow-hidden lg:flex">

        <!-- Sidebar -->
        <%- include('../partials/sidebar') %>

            <!-- Main Content -->
            <div class="flex-1 flex flex-col w-full lg:w-auto transition-transform duration-300 ease-in-out">

                <!-- Header -->
                <%- include('../partials/header') %>

                    <!-- Notes Content -->
                    <main
                        class="flex-1 overflow-x-hidden overflow-y-auto bg-gray-50 dark:bg-black p-6 animate-fade-in-up">

                        <div class="flex flex-col md:flex-row gap-6 h-full">

                            <!-- Notes List (Sidebar) -->
                            <div
                                class="w-full md:w-80 flex-shrink-0 flex flex-col bg-white dark:bg-[#1C1C1C] rounded-2xl border border-gray-200 dark:border-gray-800 overflow-hidden h-[calc(100vh-8rem)]">
                                <div
                                    class="p-4 border-b border-gray-200 dark:border-gray-800 flex justify-between items-center">
                                    <h2 class="font-bold text-lg">My Notes</h2>
                                    <button
                                        class="p-2 rounded-lg bg-[#FF6B35]/10 text-[#FF6B35] hover:bg-[#FF6B35]/20 transition-colors">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M12 4v16m8-8H4"></path>
                                        </svg>
                                    </button>
                                </div>
                                <div class="p-3">
                                    <input type="text" placeholder="Search notes..."
                                        class="w-full px-3 py-2 rounded-lg bg-gray-100 dark:bg-[#222] border-none text-sm focus:ring-1 focus:ring-[#FF6B35]">
                                </div>
                                <div class="flex-1 overflow-y-auto p-2 space-y-1">
                                    <% const notes=[ { title: 'Physics: Newton Laws' , date: '2 mins ago' ,
                                        preview: 'Three laws of motion described by Isaac Newton...' , active: true }, {
                                        title: 'Calculus Formulas' , date: 'Yesterday' ,
                                        preview: 'Derivatives of trigonometric functions...' , active: false }, {
                                        title: 'History Essay Draft' , date: 'Nov 24' ,
                                        preview: 'The impact of industrial revolution on...' , active: false }, {
                                        title: 'Project Ideas' , date: 'Nov 20' ,
                                        preview: '1. AI Tutor App 2. Weather Predictor...' , active: false } ]; %>
                                        <% notes.forEach(note=> { %>
                                            <div
                                                class="p-3 rounded-xl cursor-pointer transition-colors <%= note.active ? 'bg-orange-50 dark:bg-orange-900/20 border border-orange-200 dark:border-orange-900/50' : 'hover:bg-gray-50 dark:hover:bg-gray-800' %>">
                                                <h3 class="font-semibold text-sm text-gray-900 dark:text-white mb-1">
                                                    <%= note.title %>
                                                </h3>
                                                <p class="text-xs text-gray-500 dark:text-gray-400 line-clamp-1 mb-2">
                                                    <%= note.preview %>
                                                </p>
                                                <span class="text-[10px] text-gray-400">
                                                    <%= note.date %>
                                                </span>
                                            </div>
                                            <% }); %>
                                </div>
                            </div>

                            <!-- Editor Area -->
                            <div
                                class="flex-1 bg-white dark:bg-[#1C1C1C] rounded-2xl border border-gray-200 dark:border-gray-800 flex flex-col overflow-hidden h-[calc(100vh-8rem)]">
                                <!-- Toolbar -->
                                <div
                                    class="p-3 border-b border-gray-200 dark:border-gray-800 flex items-center gap-2 overflow-x-auto">
                                    <button
                                        class="p-2 rounded hover:bg-gray-100 dark:hover:bg-gray-800 text-gray-600 dark:text-gray-400 font-bold">B</button>
                                    <button
                                        class="p-2 rounded hover:bg-gray-100 dark:hover:bg-gray-800 text-gray-600 dark:text-gray-400 italic">I</button>
                                    <button
                                        class="p-2 rounded hover:bg-gray-100 dark:hover:bg-gray-800 text-gray-600 dark:text-gray-400 underline">U</button>
                                    <div class="w-px h-6 bg-gray-200 dark:bg-gray-700 mx-2"></div>
                                    <button
                                        class="p-2 rounded hover:bg-gray-100 dark:hover:bg-gray-800 text-gray-600 dark:text-gray-400">H1</button>
                                    <button
                                        class="p-2 rounded hover:bg-gray-100 dark:hover:bg-gray-800 text-gray-600 dark:text-gray-400">H2</button>
                                    <div class="w-px h-6 bg-gray-200 dark:bg-gray-700 mx-2"></div>
                                    <button
                                        class="p-2 rounded hover:bg-gray-100 dark:hover:bg-gray-800 text-gray-600 dark:text-gray-400">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M4 6h16M4 12h16M4 18h16"></path>
                                        </svg>
                                    </button>
                                    <div class="flex-1"></div>
                                    <button
                                        class="flex items-center gap-2 px-3 py-1.5 rounded-lg bg-[#FF6B35]/10 text-[#FF6B35] hover:bg-[#FF6B35]/20 text-sm font-medium transition-colors">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                                        </svg>
                                        AI Summarize
                                    </button>
                                </div>

                                <!-- Content -->
                                <div class="flex-1 p-8 overflow-y-auto">
                                    <input type="text" value="Physics: Newton Laws"
                                        class="w-full text-3xl font-bold bg-transparent border-none focus:outline-none mb-4 text-gray-900 dark:text-white placeholder-gray-400">
                                    <textarea
                                        class="w-full h-full bg-transparent border-none focus:outline-none resize-none text-gray-700 dark:text-gray-300 leading-relaxed"
                                        placeholder="Start typing...">Three laws of motion described by Isaac Newton:

1. Law of Inertia: An object at rest stays at rest...
2. F = ma: Force equals mass times acceleration...
3. Action-Reaction: For every action, there is an equal and opposite reaction...

Examples:
- A ball rolling on the ground stops due to friction.
- Pushing a car requires more force than pushing a bike.
- Rocket propulsion.</textarea>
                                </div>
                            </div>

                        </div>

                    </main>
            </div>
    </div>

    <!-- Mobile Sidebar Overlay -->
    <div id="sidebar-overlay" class="fixed inset-0 bg-black bg-opacity-50 z-20 hidden" onclick="toggleSidebar()"></div>

    <script src="/js/theme-manager.js"></script>
    <script>
        // Sidebar Toggle
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('sidebar-overlay');
            if (sidebar.classList.contains('-translate-x-full')) {
                sidebar.classList.remove('-translate-x-full');
                overlay.classList.remove('hidden');
            } else {
                sidebar.classList.add('-translate-x-full');
                overlay.classList.add('hidden');
            }
        }

        // Theme Toggle
        const themeToggle = document.getElementById('theme-toggle');
        themeToggle.addEventListener('click', () => {
            if (document.documentElement.classList.contains('dark')) {
                document.documentElement.classList.remove('dark');
                localStorage.setItem('theme', 'light');
            } else {
                document.documentElement.classList.add('dark');
                localStorage.setItem('theme', 'dark');
            }
        });
    </script>
</body>

</html>