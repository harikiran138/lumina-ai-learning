<!-- Chat Interface -->
<div
    class="flex-1 flex flex-col bg-gray-50 dark:bg-black overflow-hidden h-full rounded-2xl border border-gray-200 dark:border-gray-800 shadow-sm">

    <!-- Quick Actions -->
    <div
        class="px-4 py-2 bg-gray-50 dark:bg-[#0a0a0a] border-b border-gray-200 dark:border-gray-800 flex flex-wrap gap-2 text-[11px]">
        <button onclick="sendQuickMessage('Explain the Pythagorean theorem with an example')"
            class="px-3 py-1 rounded-full bg-orange-100 dark:bg-orange-900/30 text-orange-800 dark:text-orange-200 hover:bg-orange-200 dark:hover:bg-orange-900/50 transition-colors">📚
            Concept</button>
        <button onclick="sendQuickMessage('Generate 3 practice algebra problems')"
            class="px-3 py-1 rounded-full bg-blue-100 dark:bg-blue-900/30 text-blue-800 dark:text-blue-200 hover:bg-blue-200 dark:hover:bg-blue-900/50 transition-colors">✏️
            Practice</button>
        <button onclick="sendQuickMessage('Review my essay for grammar')"
            class="px-3 py-1 rounded-full bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-200 hover:bg-green-200 dark:hover:bg-green-900/50 transition-colors">✅
            Review</button>
        <button onclick="document.getElementById('knowledge-panel').classList.toggle('hidden')"
            class="px-3 py-1 rounded-full bg-purple-100 dark:bg-purple-900/30 text-purple-800 dark:text-purple-200 hover:bg-purple-200 dark:hover:bg-purple-900/50 transition-colors">📖
            Knowledge</button>
    </div>

    <!-- Knowledge Panel (Hidden) -->
    <div id="knowledge-panel"
        class="hidden border-b border-gray-200 dark:border-gray-800 p-4 bg-white dark:bg-[#111111] text-xs space-y-3 animate-fade-in-up">
        <div class="flex items-center justify-between">
            <h3 class="font-semibold text-gray-700 dark:text-gray-200">Add Custom Context</h3>
            <button onclick="this.closest('#knowledge-panel').classList.add('hidden')"
                class="text-gray-500 hover:text-gray-800 dark:hover:text-white">✕</button>
        </div>
        <textarea id="paste-knowledge" rows="3" placeholder="Paste notes or text here..."
            class="w-full text-xs p-2 rounded bg-gray-100 dark:bg-[#222] border-none focus:ring-1 focus:ring-[#FF6B35] resize-y"></textarea>
        <div class="flex gap-2">
            <button id="add-knowledge-btn"
                class="px-3 py-1.5 rounded bg-[#FF6B35] text-white text-xs hover:bg-[#E85A26]">Add Context</button>
            <label
                class="cursor-pointer px-3 py-1.5 rounded bg-gray-200 dark:bg-gray-700 text-gray-800 dark:text-gray-200 hover:bg-gray-300 dark:hover:bg-gray-600">
                📎 Upload PDF
                <input type="file" id="file-upload" class="hidden" accept="application/pdf,text/plain">
            </label>
        </div>
    </div>

    <!-- Messages Area -->
    <div id="messages-container" class="flex-1 p-6 overflow-y-auto space-y-4 scroll-smooth">
        <!-- Welcome Message -->
        <div class="flex items-start gap-3">
            <div
                class="w-8 h-8 rounded-full bg-gradient-to-br from-[#FF6B35] to-[#FF9155] flex items-center justify-center text-white font-bold text-sm">
                AI</div>
            <div
                class="bg-white dark:bg-[#1C1C1C] p-3 rounded-2xl rounded-tl-none border border-gray-200 dark:border-gray-800 max-w-[80%] shadow-sm">
                <p class="text-sm text-gray-800 dark:text-gray-200">Hello! I'm your AI Tutor. I can help you learn
                    concepts, solve problems, or review your work. What are we studying today? 🚀</p>
            </div>
        </div>
    </div>

    <!-- Input Area -->
    <div class="p-4 bg-white dark:bg-[#111111] border-t border-gray-200 dark:border-gray-800">
        <form id="message-form" class="relative flex gap-2">
            <input id="message-input" type="text" placeholder="Ask anything..."
                class="flex-1 px-4 py-3 bg-gray-100 dark:bg-[#222] border-none rounded-xl focus:ring-2 focus:ring-[#FF6B35] focus:outline-none text-sm">
            <button type="submit"
                class="px-4 py-2 bg-[#FF6B35] hover:bg-[#E85A26] text-white rounded-xl font-medium transition-colors shadow-lg shadow-orange-500/20">
                Send
            </button>
        </form>
    </div>
</div>

<script>
    // Chat Logic (Mock)
    const form = document.getElementById('message-form');
    const input = document.getElementById('message-input');
    const container = document.getElementById('messages-container');

    function addMessage(text, isUser = false) {
        const div = document.createElement('div');
        div.className = `flex items-start gap-3 ${isUser ? 'flex-row-reverse' : ''} animate-fade-in-up`;

        const avatar = isUser
            ? `<div class="w-8 h-8 rounded-full bg-gray-200 dark:bg-gray-700 flex items-center justify-center text-gray-600 dark:text-gray-300 font-bold text-sm">ME</div>`
            : `<div class="w-8 h-8 rounded-full bg-gradient-to-br from-[#FF6B35] to-[#FF9155] flex items-center justify-center text-white font-bold text-sm">AI</div>`;

        const bubble = isUser
            ? `<div class="bg-[#FF6B35] text-white p-3 rounded-2xl rounded-tr-none max-w-[80%] shadow-md"><p class="text-sm">${text}</p></div>`
            : `<div class="bg-white dark:bg-[#1C1C1C] p-3 rounded-2xl rounded-tl-none border border-gray-200 dark:border-gray-800 max-w-[80%] shadow-sm"><p class="text-sm text-gray-800 dark:text-gray-200">${text}</p></div>`;

        div.innerHTML = avatar + bubble;
        container.appendChild(div);
        container.scrollTop = container.scrollHeight;
    }

    function sendQuickMessage(text) {
        addMessage(text, true);
        setTimeout(() => addMessage("That's a great topic! Let's dive into it. Here's a structured breakdown...", false), 1000);
    }

    form.addEventListener('submit', (e) => {
        e.preventDefault();
        const text = input.value.trim();
        if (!text) return;
        addMessage(text, true);
        input.value = '';
        setTimeout(() => addMessage("I'm processing your request using the latest AI models...", false), 1000);
    });
</script>