<!-- Course Explorer Content -->
<div class="animate-fade-in-up">
    <!-- Search & Filter -->
    <div class="mb-8 flex flex-col md:flex-row gap-4 items-center justify-between">
        <div class="relative w-full md:w-96">
            <input type="text" placeholder="Search courses..."
                class="w-full pl-10 pr-4 py-2.5 rounded-xl bg-white dark:bg-[#1C1C1C] border border-gray-200 dark:border-gray-800 focus:ring-2 focus:ring-[#FF6B35] focus:outline-none text-sm">
            <svg class="w-5 h-5 text-gray-400 absolute left-3 top-2.5" fill="none" stroke="currentColor"
                viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
        </div>
        <div class="flex gap-2 w-full md:w-auto overflow-x-auto pb-2 md:pb-0">
            <button
                class="px-4 py-2 rounded-lg bg-[#FF6B35] text-white text-sm font-medium shadow-lg shadow-orange-500/20 whitespace-nowrap">All
                Courses</button>
            <button
                class="px-4 py-2 rounded-lg bg-white dark:bg-[#1C1C1C] border border-gray-200 dark:border-gray-800 text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800 text-sm font-medium whitespace-nowrap transition-colors">Science</button>
            <button
                class="px-4 py-2 rounded-lg bg-white dark:bg-[#1C1C1C] border border-gray-200 dark:border-gray-800 text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800 text-sm font-medium whitespace-nowrap transition-colors">Math</button>
            <button
                class="px-4 py-2 rounded-lg bg-white dark:bg-[#1C1C1C] border border-gray-200 dark:border-gray-800 text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800 text-sm font-medium whitespace-nowrap transition-colors">Programming</button>
        </div>
    </div>

    <!-- Featured Course -->
    <div class="mb-8 relative rounded-2xl overflow-hidden group cursor-pointer">
        <div class="absolute inset-0 bg-gradient-to-r from-black/80 to-transparent z-10"></div>
        <img src="https://images.unsplash.com/photo-1635070041078-e363dbe005cb?q=80&w=2070&auto=format&fit=crop"
            alt="Featured" class="w-full h-64 object-cover group-hover:scale-105 transition-transform duration-500">
        <div class="absolute bottom-0 left-0 p-8 z-20 max-w-2xl">
            <span
                class="px-3 py-1 rounded-full bg-[#FF6B35] text-white text-xs font-bold mb-3 inline-block">FEATURED</span>
            <h2 class="text-3xl font-bold text-white mb-2">Advanced Neural Networks</h2>
            <p class="text-gray-200 mb-4 line-clamp-2">Master deep learning architectures, backpropagation, and build
                your own AI models from scratch using Python and TensorFlow.</p>
            <button
                class="px-6 py-2.5 bg-white text-black rounded-lg font-semibold hover:bg-gray-100 transition-colors">Start
                Learning</button>
        </div>
    </div>

    <!-- Course Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% courses.forEach(course=> { %>
            <div
                class="bg-white dark:bg-[#1C1C1C] rounded-2xl overflow-hidden border border-gray-100 dark:border-gray-800 hover:shadow-lg transition-all hover:-translate-y-1 group cursor-pointer">
                <div class="relative h-40 overflow-hidden">
                    <img src="<%= course.image %>" alt="<%= course.title %>"
                        class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                    <div
                        class="absolute top-3 right-3 bg-black/50 backdrop-blur-md px-2 py-1 rounded text-xs text-white font-medium">
                        <%= course.category %>
                    </div>
                </div>
                <div class="p-5">
                    <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">
                        <%= course.title %>
                    </h3>
                    <div class="flex items-center justify-between text-sm text-gray-500 dark:text-gray-400 mb-4">
                        <span>12 Lessons</span>
                        <span>4.8 ⭐</span>
                    </div>
                    <% if (course.progress> 0) { %>
                        <% const colorMap={ 'blue' : '#3B82F6' , 'purple' : '#A855F7' , 'green' : '#10B981' , 'orange'
                            : '#FF6B35' , 'red' : '#EF4444' , 'yellow' : '#F59E0B' }; const
                            bgColor=colorMap[course.color] || '#3B82F6' ; %>
                            <div class="w-full bg-gray-100 dark:bg-gray-800 rounded-full h-1.5 mb-2">
                                <div class="h-1.5 rounded-full"
                                    style="width: <%= course.progress %>%; background-color: <%= bgColor %>;"></div>
                            </div>
                            <p class="text-xs font-medium" style="color: <%= bgColor %>;">
                                <%= course.progress %>% Complete
                            </p>
                            <% } else { %>
                                <button
                                    class="w-full py-2 rounded-lg border border-gray-200 dark:border-gray-700 text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800 text-sm font-medium transition-colors">Enroll
                                    Now</button>
                                <% } %>
                </div>
            </div>
            <% }); %>
    </div>
</div>